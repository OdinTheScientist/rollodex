<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rollodex" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rollodex">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="fixed top-0 inset-x-0 z-50 bg-white border-b border-gray-100 shadow-sm">
      <div class="container mx-auto px-5 h-14 flex items-center justify-between">
        <span class="text-sm font-bold tracking-widest uppercase text-slate-400">Rollodex</span>
        <div class="flex gap-1">
          <% [["Positions", positions_path, "positions"], ["Techniques", techniques_path, "techniques"]].each do |label, path, ctrl| %>
            <%= link_to label, path,
                  class: [
                    "px-4 py-1.5 rounded-lg text-sm font-semibold transition-colors duration-150",
                    controller_name == ctrl ? "bg-slate-900 text-white" : "text-slate-500 hover:text-slate-900 hover:bg-slate-100"
                  ].join(" ") %>
          <% end %>
        </div>
      </div>
    </nav>
    <main class="container mx-auto mt-20 px-5">
      <%= yield %>
    </main>
  </body>
</html>
