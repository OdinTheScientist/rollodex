<%= form_with url: url, method: :get, class: "mb-6",
      data: { controller: "search" } do |f| %>
  <div class="relative">
    <%= f.text_field :q, value: params[:q],
          placeholder: placeholder,
          autocomplete: "off",
          data: { action: "input->search#search", search_target: "input" },
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 pr-9 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
    <button type="button" hidden
            data-search-target="clear"
            data-action="click->search#clear"
            class="absolute inset-y-0 right-3 flex items-center text-gray-400 hover:text-gray-600">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 8.586L4.707 3.293a1 1 0 00-1.414 1.414L8.586 10l-5.293 5.293a1 1 0 101.414 1.414L10 11.414l5.293 5.293a1 1 0 001.414-1.414L11.414 10l5.293-5.293a1 1 0 00-1.414-1.414L10 8.586z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
<% end %>
