<% content_for :head do %>
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
<% end %>

<%= form_with model: @resource, class: "space-y-6" do |f| %>
  <% if @resource.errors.any? %>
    <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3">
      <p class="text-xs font-semibold uppercase tracking-widest text-rose-500 mb-2">
        <%= pluralize(@resource.errors.count, "error") %> prevented this resource from saving
      </p>
      <ul class="space-y-1">
        <% @resource.errors.full_messages.each do |message| %>
          <li class="text-sm text-rose-700"><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_field :title,
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
  </div>

  <div>
    <%= f.label :url, "URL", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_field :url,
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
  </div>

  <div>
    <%= f.label :resource_type, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.select :resource_type,
          Resource.resource_types.keys.map { |t| [ t.humanize, t ] },
          {},
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400 bg-white" %>
  </div>

  <div>
    <%= f.label :gi_nogi, "Gi / No-Gi", class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.select :gi_nogi,
          Resource.gi_nogis.keys.map { |t| [ t.humanize, t ] },
          {},
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400 bg-white" %>
  </div>

  <div>
    <%= f.label :instructor_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_field :instructor_name,
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400" %>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
    <%= f.text_area :notes, rows: 4,
          class: "w-full rounded-xl border border-gray-200 px-4 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-slate-400 resize-none" %>
  </div>

  <div class="flex items-start gap-3">
    <%= f.check_box :foundational, class: "mt-0.5 h-4 w-4 rounded border-gray-300 text-slate-700 focus:ring-slate-400" %>
    <div>
      <%= f.label :foundational, class: "block text-sm font-medium text-gray-700" %>
      <p class="text-xs text-gray-400 mt-0.5">When checked, this resource appears on all positions where its linked techniques appear.</p>
    </div>
  </div>

  <% technique_ids = @resource.persisted? ? @resource.technique_ids : (@preselected_technique_ids || []) %>
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1.5">Techniques</label>
    <select id="resource_technique_ids" name="resource[technique_ids][]" multiple class="w-full">
      <% @techniques.each do |t| %>
        <option value="<%= t.id %>" <%= "selected" if technique_ids.include?(t.id) %>><%= t.name %></option>
      <% end %>
    </select>
  </div>

  <% position_ids = @resource.persisted? ? @resource.position_ids : (@preselected_position_ids || []) %>
  <div>
    <label class="block text-sm font-medium text-gray-700 mb-1.5">Positions</label>
    <select id="resource_position_ids" name="resource[position_ids][]" multiple class="w-full">
      <% @positions.each do |p| %>
        <option value="<%= p.id %>" <%= "selected" if position_ids.include?(p.id) %>><%= p.name %></option>
      <% end %>
    </select>
  </div>

  <%= f.submit class: "px-4 py-2 rounded-xl bg-slate-900 text-white text-sm font-semibold shadow hover:bg-slate-700 transition-colors duration-150 cursor-pointer" %>
<% end %>

<script>
  function initResourceTomSelects() {
    if (typeof TomSelect === "undefined") return;
    var techEl = document.getElementById("resource_technique_ids");
    var posEl  = document.getElementById("resource_position_ids");
    if (techEl && !techEl.tomselect) new TomSelect(techEl, { plugins: ["remove_button"] });
    if (posEl  && !posEl.tomselect)  new TomSelect(posEl,  { plugins: ["remove_button"] });
  }
  document.addEventListener("turbo:load", initResourceTomSelects);
  initResourceTomSelects();
</script>
